{%- comment -%}
  ES · Badges de envío — va ARRIBA del co-couriers block.
  Envío gratis + pago contra reembolso + derecho de desistimiento UE (14 días).
{%- endcomment -%}

<div class="co-ml-full">

  <div class="co-ml-full__badge co-ml-full__badge--delivery">
    <span class="co-ml-full__truck" aria-hidden="true">🚚</span>
    <span class="co-ml-full__badge-text">Envío GRATIS a toda España</span>
  </div>

  <div class="co-ml-full__badge co-ml-full__badge--return">
    <span class="co-ml-full__return-icon" aria-hidden="true">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#00a650" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
    </span>
    <span>
      <span class="co-ml-full__return-title">Pagas contra reembolso</span>
      <span class="co-ml-full__return-sub">al recibirlo · 14 días para devolver</span>
    </span>
  </div>

</div>

<style>
  .co-ml-full {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 14px 18px;
    background: #f5faf6;
    border: 1px solid #b2dfba;
    border-radius: 12px;
    margin: 12px 0 8px;
    text-align: center;
  }
  .co-ml-full__badge {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .co-ml-full__badge--delivery {
    background: #e8f5e9;
    border-radius: 8px;
    padding: 8px 16px;
    flex-wrap: wrap;
    gap: 8px;
    width: 100%;
  }
  .co-ml-full__truck { font-size: 1.2rem; }
  .co-ml-full__badge-text {
    font-size: 1.15rem;
    font-weight: 700;
    color: #00a650;
  }
  .co-ml-full__badge--return {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 2px 6px;
  }
  .co-ml-full__return-icon { display: flex; align-items: center; }
  .co-ml-full__return-title {
    display: block;
    font-size: 1.1rem;
    font-weight: 700;
    color: #00a650;
  }
  .co-ml-full__return-sub {
    display: block;
    font-size: 1rem;
    color: #555;
  }
</style>
